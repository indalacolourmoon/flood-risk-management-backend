# Environment Variables — copy to .env and fill in real values
# DO NOT commit the actual .env file to version control

# API Configuration
APP_ENV=development
APP_PORT=8000

# CORS — comma-separated origins allowed to call this API
ALLOWED_ORIGINS=http://localhost:3000,https://your-app.vercel.app

# Data Paths (override defaults if deploying to PythonAnywhere)
# YEAR1_CSV=/home/yourusername/flood-api/data/year1.csv
# YEAR2_CSV=/home/yourusername/flood-api/data/year2.csv
